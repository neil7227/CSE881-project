%--------------------------------------
%  Color Settings
%--------------------------------------

% define custom colors
\definecolor{dexpiBlue}{HTML}{2A578B}
\definecolor{dexpiLightBlue}{HTML}{CDE3F1}
\definecolor{dexpiWhite}{HTML}{FFFFFF}
\definecolor{dexpiBlueDark}{HTML}{1F3F66}     % darker variant
\definecolor{dexpiBlueLight}{HTML}{E6F2FA}    % lighter variant

\definecolor{dexpiGreen}{HTML}{3FAF8C}
\definecolor{dexpiGreenDark}{HTML}{2F8A6E}
\definecolor{dexpiGreenLight}{HTML}{DDF3EC}

\definecolor{dexpiRed}{HTML}{C94A4A}
\definecolor{dexpiRedDark}{HTML}{9E3636}
\definecolor{dexpiRedLight}{HTML}{F6DADA}

% customize colors for elements
\setbeamercolor{frametitle}{fg=dexpiBlue}
\setbeamercolor{structure}{fg=dexpiBlue}
\setbeamercolor{normal text}{fg=dexpiBlue, bg=white}
\setbeamercolor{footer}{fg=dexpiBlue}
\setbeamercolor{date}{fg=dexpiBlue}


% Block colors (add)
\setbeamercolor{block title}{fg=dexpiBlueLight,bg=dexpiBlue}
\setbeamercolor{block body}{fg=dexpiBlue,bg=dexpiBlueLight}

\setbeamercolor{block title alerted}{fg=dexpiRedLight,bg=dexpiRedDark}
\setbeamercolor{block body alerted}{fg=dexpiRedDark,bg=dexpiRedLight}

\setbeamercolor{block title example}{fg=dexpiGreenLight, bg=dexpiGreenDark}
\setbeamercolor{block body example}{fg=dexpiGreenDark,bg=dexpiGreenLight}
