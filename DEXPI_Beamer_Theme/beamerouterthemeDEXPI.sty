%--------------------------------------
%  Outer Theme Settings
%--------------------------------------
% beamerouterthemeDEXPI.sty
\ProvidesPackage{beamerouterthemeDEXPI}

% Hintergrund definieren
\usebackgroundtemplate{
  \begin{tikzpicture}[remember picture, overlay]
    \fill[dexpiLightBlue]
      ([xshift=-4cm]current page.north east) --
      (current page.north east) --
      ([yshift=1cm]current page.south east) --
      ([xshift=-6cm,yshift=1cm]current page.south east) --
      cycle;
  \end{tikzpicture}
}

% Footer-Template definieren
\setbeamertemplate{footline}{
  \begin{tikzpicture}[remember picture, overlay]
    \draw[dexpiBlue, line width=1pt]
      ([xshift=-0.2cm,yshift=0.2cm]current page.south west) --
      ([xshift=0.8cm,yshift=-0.8cm]current page.south west);
  \end{tikzpicture}
  \leavevmode
  \hbox to \paperwidth{%
    
    \begin{beamercolorbox}[wd=0.2\paperwidth,ht=0.7cm,dp=0.3cm,left]{date}
        \hspace*{0.2cm}
        \usebeamercolor{footer}
        \insertshortdate
    \end{beamercolorbox}%
    
    \begin{beamercolorbox}[wd=0.53\paperwidth, ht=0.7cm,dp=0.3cm,left]{date}
      \insertsection 
    \end{beamercolorbox}%

    \begin{beamercolorbox}[wd=0.15\paperwidth,ht=0.5cm,dp=0.2cm,right]{logo in head/foot}
      \vspace{0.5cm}
      \includegraphics[height=0.6cm]{img/dexpi_logo.png}
    \end{beamercolorbox}
    
    \begin{beamercolorbox}[wd=0.05\paperwidth,ht=0.7cm,right]{logo in head/foot}
        \vspace{0.12cm}
        \usebeamercolor{footer}
        \insertframenumber{}
    \end{beamercolorbox}
    }
}
